{
  "name": "flashcard-mobile-webview-shell",
  "version": "1.0.0",
  "private": true,
  "main": "expo/AppEntry",
  "scripts": {
    "start": "expo start",
    "start:tunnel": "node ./scripts/start-tunnel-retry.mjs",
    "start:lan": "expo start --lan --clear",
    "start:localhost": "expo start --localhost --clear",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "sync-web": "node ./scripts/sync-web-assets.mjs",
    "prepare-web": "npm run sync-web",
    "check": "tsc --noEmit"
  },
  "dependencies": {
    "@expo/ngrok": "^4.1.3",
    "cross-spawn": "7.0.6",
    "expo": "~54.0.33",
    "expo-asset": "~12.0.12",
    "expo-file-system": "~19.0.21",
    "expo-notifications": "~0.32.16",
    "expo-status-bar": "~3.0.8",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-web": "^0.21.0",
    "react-native-webview": "13.15.0"
  },
  "devDependencies": {
    "@types/react": "~19.1.10",
    "babel-preset-expo": "~54.0.10",
    "typescript": "~5.9.2"
  }
}
